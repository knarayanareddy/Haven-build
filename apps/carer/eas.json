{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "corepack": true,
      "pnpm": "9.12.3",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "development",
        "EXPO_PUBLIC_SUPABASE_URL": "http://127.0.0.1:54321",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_LOCAL_SUPABASE_ANON_KEY"
      }
    },
    "preview": {
      "corepack": true,
      "pnpm": "9.12.3",
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "latest",
        "withoutCredentials": true
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "staging"
      }
    },
    "production": {
      "corepack": true,
      "pnpm": "9.12.3",
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_HAVEN_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ci@haven.nl",
        "ascAppId": "6472026112",
        "appleTeamId": "NLHAVEN99"
      },
      "android": {
        "serviceAccountKeyPath": "./google-api-key.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
