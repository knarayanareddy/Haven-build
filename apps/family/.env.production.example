# ─────────────────────────────────────────────────────────────────────────────
# HAVEN Family Dashboard — Production Environment Template
# Copy to .env.production.local and fill in values from Supabase dashboard
# DO NOT commit .env.production.local — it is gitignored
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# Supabase anon/public key (Settings → API → Project API Keys → anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_ANON_KEY>

# Environment identifier — must be "production" in prod
NEXT_PUBLIC_ENV=production

# Default locale
NEXT_PUBLIC_LOCALE=nl-NL
